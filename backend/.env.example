# Database (Neon / Supabase / local Postgres)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# hCaptcha (already configured with your real keys)
HCAPTCHA_SECRET=your-hcaptcha-secret-key
HCAPTCHA_SITEKEY=your-hcaptcha-site-key

# Email notifications — use Gmail App Password
# (Gmail > Settings > Security > 2FA on > App Passwords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-16-char-app-password

# Who receives booking notifications
NOTIFY_EMAIL=fermin.aguilar.b@gmail.com
